#!/bin/bash
set -e

if [ "$#" -gt 1 ]; then
  echo "usage: sprt [stc|ltc]"
  exit 1
fi

rm -f sprt.pgn

e1=./cwtch_test
e2=./cwtch_base

elo0=0
elo1=10
concurrency=15
book=UHO_Lichess_4852_v1.epd

if [ "$1" = "ltc" ]; then
  hash=256
  tc=40+0.4
  shift
else
  hash=16
  tc=8+0.08
  [ "$1" = "stc" ] && shift
fi

e1name="Cwtch_Test"
e2name="Cwtch_Base"

~/fastchess/fastchess -recover -concurrency $concurrency -rounds 10000 -repeat \
-resign movecount=5 score=600 \
-draw movenumber=40 movecount=8 score=5 \
-engine cmd=$e1 proto=uci tc=$tc timemargin=250 option.Hash=$hash name=$e1name \
-engine cmd=$e2 proto=uci tc=$tc timemargin=250 option.Hash=$hash name=$e2name \
-openings file=./$book format=epd order=random -srand $RANDOM \
-sprt elo0=$elo0 elo1=$elo1 alpha=0.05 beta=0.1 \
-pgnout file=sprt.pgn