#!/bin/bash
set -e

if [ "$1" = "kill" ]; then
  PIDS=$(pgrep -f "cwtch datagen" 2>/dev/null || true)
  if [ -z "$PIDS" ]; then
    echo "no datagen processes found"
  else
    echo "$PIDS" | xargs kill
    echo "killed $(echo "$PIDS" | wc -l) datagen processes"
  fi
  exit 0
fi

if [ "$#" -ne 3 ]; then
  echo "usage: datagen <directory> <hours> <threads>"
  echo "       datagen kill"
  exit 1
fi

DIR="$1"
HOURS="$2"
THREADS="$3"

mkdir -p "$DIR"

if [ "$(ls -A "$DIR" 2>/dev/null)" ]; then
  echo "warning: $DIR is not empty"
  read -p "continue? [y/N] " answer
  if [ "$answer" != "y" ] && [ "$answer" != "Y" ]; then
    echo "aborted"
    exit 1
  fi
fi

for i in $(seq 1 "$THREADS"); do
  sleep $(awk "BEGIN{printf \"%.2f\", rand() * 3}" <<< "$RANDOM")
  ./cwtch "datagen $DIR $HOURS" &
done

echo "launched $THREADS datagen processes for $HOURS hours writing to $DIR"
wait
echo "all datagen processes complete"
